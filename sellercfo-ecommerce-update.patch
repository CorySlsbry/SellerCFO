+                placeholder="••••••••"
+                required
+                className="w-full px-4 py-2 rounded bg-[#0a0a0f] border border-[#1e1e2e] text-[#e8e8f0] placeholder-[#8888a0] focus:outline-none focus:border-[#06b6d4] transition"
+              />
+            </div>
+
+            {/* Confirm Password Field */}
+            <div>
+              <label

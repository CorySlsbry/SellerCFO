+
+function PLReportContent({ data }: { data: any }) {
+  const totalRevenue = data.revenues.reduce((sum: number, item: any) => sum + item.amount, 0);
+  const totalExpenses = data.expenses.reduce((sum: number, item: any) => sum + item.amount, 0);

+                    return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
+                  }}
+                />
+                <Area
+                  type="monotone"
+                  dataKey="views"
+                  stroke="#06b6d4"
+                  strokeWidth={2}
+                  fill="url(#viewsGrad)"
+                  name="Page Views"
+                  isAnimationActive={false}
+                />
+                <Area
+                  type="monotone"
+                  dataKey="signups"
+                  stroke="#22c55e"
+                  strokeWidth={2}
+                  fill="url(#signupsGrad)"
+                  name="Signups"

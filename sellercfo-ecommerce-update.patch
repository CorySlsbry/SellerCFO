-/**
- * Creates financial metrics from dashboard data
- */
-export function createMetrics(dashboardData: {
-  revenue: number;
-  expenses: number;
-  profit: number;
-  cash_balance: number;
-}): FinancialMetric[] {
-  const profitMargin =
-    dashboardData.revenue > 0

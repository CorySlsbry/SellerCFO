# ═══════════════════════════════════════════════════════════════
# SellerCFO — Environment Variables
# Copy to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── App ───
NEXT_PUBLIC_APP_URL="https://sellercfo.vercel.app"
NEXT_PUBLIC_VERTICAL_NAME="SellerCFO"
NEXT_PUBLIC_VERTICAL_SLUG="sellercfo"
NEXT_PUBLIC_ACCENT_COLOR="#8b5cf6"

# ─── Supabase (Project: njqhrihwigienamvhidg) ───
NEXT_PUBLIC_SUPABASE_URL="https://njqhrihwigienamvhidg.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Stripe ───
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (SellerCFO products — created 2026-04-06)
# Essential  $199/mo — prod_UHuvCDUrQgP6nX
STRIPE_PRICE_ID_ESSENTIAL="price_1TJL64R3iue4PpolX1iPSZpM"
# Professional $399/mo — prod_UHuvVumJfsLSxp
STRIPE_PRICE_ID_PRO="price_1TJL65R3iue4PpolPnkJ97IU"
# Enterprise $799/mo — prod_UHuvT9BUUAa3iE
STRIPE_PRICE_ID_ENTERPRISE="price_1TJL66R3iue4PpolqEnWAJCY"

# ─── Anthropic (AI CFO Advisor + Landing Chat) ───
ANTHROPIC_API_KEY=""

# ─── Google Calendar (Booking) ───
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REFRESH_TOKEN=""

# ─── GoHighLevel (CRM) ───
GHL_API_KEY=""
GHL_LOCATION_ID=""

# ─── Resend (Emails) ───
RESEND_API_KEY=""

# ═══════════════════════════════════════════════════════════════
# Integration Connectors — Developer Account Credentials
# ═══════════════════════════════════════════════════════════════

# ─── QuickBooks Online (already connected via /api/qbo/) ───
# Sign up: https://developer.intuit.com
# Create app → Keys & credentials → Production keys
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
QBO_REDIRECT_URI="https://topsellercfo.com/api/qbo/callback"

# ─── Xero ───
# Sign up: https://developer.xero.com/app/manage
# Create app → OAuth 2.0 → Web App
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
XERO_REDIRECT_URI="https://topsellercfo.com/api/integrations/callback?provider=xero"

# ─── Shopify ───
# Sign up: https://partners.shopify.com → Create App → Custom App
# Scopes: read_orders, read_products, read_inventory, read_analytics
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""
SHOPIFY_REDIRECT_URI="https://topsellercfo.com/api/integrations/callback?provider=shopify"

# ─── Amazon Selling Partner API ───
# Sign up: https://sellercentral.amazon.com → Apps & Services → Develop Apps
# Then register at https://developer.amazonservices.com
AMAZON_SP_CLIENT_ID=""
AMAZON_SP_CLIENT_SECRET=""
AMAZON_SP_REDIRECT_URI="https://topsellercfo.com/api/integrations/callback?provider=amazon"
AMAZON_SP_REFRESH_TOKEN=""

# ─── Etsy ───
# Sign up: https://www.etsy.com/developers → Create New App
# Scopes: transactions_r, listings_r, shops_r
ETSY_API_KEY=""
ETSY_SHARED_SECRET=""
ETSY_REDIRECT_URI="https://topsellercfo.com/api/integrations/callback?provider=etsy"

# ─── WooCommerce (API Key auth — no developer account needed) ───
# Configured per-store by the user in Settings → WooCommerce → REST API
# No env vars needed — credentials stored per-org in Supabase

# ─── Walmart Marketplace ───
# Sign up: https://developer.walmart.com → Create Application
WALMART_CLIENT_ID=""
WALMART_CLIENT_SECRET=""

# ─── TikTok Shop ───
# Sign up: https://partner.tiktokshop.com → Become a Partner → Create App
TIKTOK_SHOP_APP_KEY=""
TIKTOK_SHOP_APP_SECRET=""
TIKTOK_SHOP_REDIRECT_URI="https://topsellercfo.com/api/integrations/callback?provider=tiktok_shop"
